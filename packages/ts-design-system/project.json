{
  "name": "ts-design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ts-design-system/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:ui", "scope:design-system"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/ts-design-system/jest.config.ts",
        "tsConfig": "packages/ts-design-system/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "packages/ts-design-system/.storybook",
        "browserTarget": "ts-design-system:build-storybook",
        "tsConfig": "packages/ts-design-system/.storybook/tsconfig.json",
        "styles": [
          "packages/design-tokens/src/styles/primitives.css",
          "packages/design-tokens/src/styles/semantic.css",
          "packages/design-tokens/src/styles/components.css"
        ],
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      },
      "parallelism": true
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/ts-design-system",
        "configDir": "packages/ts-design-system/.storybook",
        "browserTarget": "ts-design-system:build-storybook",
        "tsConfig": "packages/ts-design-system/.storybook/tsconfig.json",
        "styles": [
          "packages/design-tokens/src/styles/primitives.css",
          "packages/design-tokens/src/styles/semantic.css",
          "packages/design-tokens/src/styles/components.css"
        ],
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      },
      "parallelism": true
    }
  }
}
