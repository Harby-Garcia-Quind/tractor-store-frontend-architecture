{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tractor/domain": [
        "packages/playground/domain.models.ts"
      ],
      "@tractor/domain/*": [
        "packages/playground/domain/*"
      ]
    }
  },
  "include": [
    "packages/playground/**/*.ts"
  ]
}
