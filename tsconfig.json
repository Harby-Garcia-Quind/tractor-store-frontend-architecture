{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "paths": {
      "@tractor/domain": ["./playground/domain.models.ts"],
      "@tractor/domain/*": ["./playground/domain/*"]
    }
  },
  "include": ["playground/**/*.ts"]
}